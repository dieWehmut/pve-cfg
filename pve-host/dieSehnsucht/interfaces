auto lo
iface lo inet loopback

auto nic0
iface nic0 inet manual

iface wlp174s0 inet manual

auto vmbr0
iface vmbr0 inet static
	address 192.168.10.2/24
	gateway 192.168.10.1
	bridge-ports nic0
	bridge-stp off
	bridge-fd 0
	bridge-vlan-aware yes
	bridge-vids 2-4094
		post-up ip route add 192.168.0.0/16 via 192.168.10.10
		post-down ip route del 192.168.0.0/16 via 192.168.10.10	       
source /etc/network/interfaces.d/*
iface vmbr0 inet6 auto
    accept_ra 2
