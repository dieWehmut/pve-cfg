config interface 'wg0'
	option proto 'wireguard'
	option private_key 'REDACTED'
	list addresses '10.254.254.3/32'
	list dns '8.8.8.8'
	list dns '1.1.1.1'
	list dns '1.1.1.1'
	list dns '8.8.8.8'
	option route_allowed_ips '1'
	option peerdns '0'
	option mtu '1280'

config wireguard_wg0
	option public_key 'SIUpMbU+7h5bUyqN58zByXxnuxagAQxaGStX5/IZGwQ='
	option endpoint_host '10.50.248.87'
	option endpoint_port '40090'
	option persistent_keepalive '25'
	option route_allowed_ips '1'
	list allowed_ips '0.0.0.0/0'
	list allowed_ips '::/0'

